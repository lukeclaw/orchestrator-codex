{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/refs/heads/dev/crates/tauri-schema-generator/schemas/config.schema.json",
  "productName": "Orchestrator",
  "version": "0.4.3",
  "identifier": "com.yudongqiu.orchestrator",
  "build": {
    "frontendDist": "./loading",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd frontend && npm run dev"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Orchestrator",
        "width": 1600,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src http://127.0.0.1:8093 ws://127.0.0.1:8093 http://localhost:8093 ws://localhost:8093 http://localhost:5173 ws://localhost:5173; img-src http://127.0.0.1:8093 http://localhost:8093 data: blob:; font-src data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "resources": [
      "binaries/orchestrator-server-sidecar/**/*"
    ],
    "category": "public.app-category.productivity",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": "Developer ID Application: Yudong Qiu (XT8BC8793B)",
      "entitlements": "./Entitlements.plist"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE3QUI2Njg1NDNBRkE3OTUKUldTVnA2OURoV2FycDU0M0JoZlpHdEJJYU9md1pKM2paeC9Eb01iYWhhV3hiU1poaSsrZTRsN3gK",
      "endpoints": [
        "https://github.com/yudongqiu/orchestrator/releases/latest/download/latest.json"
      ]
    }
  }
}
