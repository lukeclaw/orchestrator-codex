{
  "identifier": "default",
  "description": "Default capabilities for Orchestrator",
  "windows": ["main"],
  "remote": {
    "urls": ["http://127.0.0.1:8093/*", "http://localhost:8093/*"]
  },
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/orchestrator-server",
          "sidecar": true
        }
      ]
    },
    "shell:allow-open",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "process:default",
    "opener:default",
    "updater:default"
  ]
}
