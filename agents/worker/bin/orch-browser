#!/bin/bash
# orch-browser: Launch and manage a browser for web tasks
#
# Launches a headless Chromium with CDP, creates an SSH tunnel + browser view
# visible in the operator's dashboard, and configures Playwright MCP tools
# to connect to the same browser instance.
#
# Browser lifecycle is managed by the RWS daemon when available, with fallback
# to direct launch when the daemon is not running.
#
# Usage:
#   orch-browser --start [--port PORT]  Launch browser + tunnel + view + MCP
#   orch-browser --close                Close browser view, kill browser, remove MCP
#   orch-browser --status               Check browser/view status
#   orch-browser --minimize             Minimize browser view overlay
#   orch-browser --restore              Restore browser view overlay
#   orch-browser --install              Install Playwright Chromium browser
#   orch-browser -h, --help             Show this help message

set -e

source "$(dirname "$0")/lib.sh"

DEFAULT_PORT=9222
PIDFILE_DIR="/tmp/orchestrator"
LOG_DIR="/tmp/orchestrator"

show_help() {
    echo "Usage: orch-browser <command> [options]"
    echo ""
    echo "Launch and manage a browser for web tasks. The browser is visible to the"
    echo "operator in the dashboard and shared with Playwright MCP tools."
    echo ""
    echo "Commands:"
    echo "  --start [--port PORT]  Launch browser + open dashboard view + configure MCP"
    echo "                         Default port: $DEFAULT_PORT"
    echo "  --close                Close browser view, kill browser, remove MCP config"
    echo "  --status               Check if browser and view are running"
    echo "  --minimize             Minimize browser view overlay in dashboard"
    echo "  --restore              Restore browser view overlay in dashboard"
    echo "  --install              Install Playwright Chromium if missing"
    echo "  -h, --help             Show this help"
    echo ""
    echo "After --start, Playwright MCP tools (browser_navigate, browser_click, etc.)"
    echo "connect to the same browser the operator sees in the dashboard."
}

if [ -z "$SESSION_ID" ]; then
    echo "Error: ORCH_SESSION_ID not set" >&2
    exit 1
fi

pidfile() {
    echo "$PIDFILE_DIR/browser-$SESSION_ID.pid"
}

logfile() {
    echo "$LOG_DIR/browser-$SESSION_ID.log"
}

# Ensure system fonts are installed so Chromium renders text properly.
# On headless Linux servers, default font packages are often missing,
# causing garbled/box characters in the browser.
ensure_fonts() {
    # Quick check: if liberation fonts exist, skip install
    if fc-list 2>/dev/null | grep -qi "liberation\|noto" ; then
        return 0
    fi
    echo "Installing system fonts for Chromium..." >&2

    # Use Playwright's official deps installer (handles distro detection + fonts)
    if command -v npx &>/dev/null; then
        if npx playwright install-deps chromium >&2 2>&1; then
            fc-cache -f 2>/dev/null || true
            return 0
        fi
        echo "Warning: Could not install system fonts via playwright install-deps" >&2
    else
        echo "Warning: npx not found, cannot install system fonts" >&2
    fi
}

# Find the Chromium binary from Playwright cache or PATH.
# Prints the path to stdout. Returns 1 if not found.
find_chromium() {
    local pw_dir="$HOME/.cache/ms-playwright"
    # Search for chrome/chromium binaries in Playwright cache.
    # Different Playwright versions and fallback builds use different
    # directory layouts (chrome-linux/, chrome/, platform-specific, etc.)
    # so we search broadly for known binary names.
    local chrome_path
    for name in chrome headless_shell chromium; do
        while IFS= read -r chrome_path; do
            if [[ -x "$chrome_path" ]]; then
                echo "$chrome_path"
                return 0
            fi
        done < <(find "$pw_dir" -path "*/chromium*/$name" -type f 2>/dev/null | sort -r)
    done
    # Check PATH
    for name in chromium-browser chromium google-chrome chrome; do
        if command -v "$name" &>/dev/null; then
            command -v "$name"
            return 0
        fi
    done
    return 1
}

# Wait for CDP endpoint to become available
wait_for_cdp() {
    local port="$1"
    local max_attempts=20
    for i in $(seq 1 "$max_attempts"); do
        if curl -sf "http://localhost:$port/json/version" &>/dev/null; then
            return 0
        fi
        sleep 0.5
    done
    return 1
}

# Launch headless Chromium with CDP enabled (fallback when daemon is unavailable).
# Tries to find the Chromium binary directly first, then falls back to Node/Playwright.
launch_browser() {
    local port="$1"
    mkdir -p "$PIDFILE_DIR" "$LOG_DIR"

    # Strategy 1: Launch Chromium binary directly (no Node.js needed)
    local chromium_bin
    if chromium_bin=$(find_chromium); then
        echo "Found Chromium at $chromium_bin" >&2
        nohup "$chromium_bin" \
            --headless \
            --no-sandbox \
            --disable-gpu \
            --disable-dev-shm-usage \
            --remote-debugging-port="$port" \
            --remote-debugging-address=127.0.0.1 \
            about:blank \
            > "$(logfile)" 2>&1 &
        echo $! > "$(pidfile)"
        return 0
    fi

    # Strategy 2: Install Chromium via Playwright and then launch the binary
    echo "Chromium not found, installing via Playwright..." >&2
    npx playwright install chromium >&2
    ensure_fonts

    # After install, try to find the binary again
    if chromium_bin=$(find_chromium); then
        echo "Found Chromium at $chromium_bin" >&2
        nohup "$chromium_bin" \
            --headless \
            --no-sandbox \
            --disable-gpu \
            --disable-dev-shm-usage \
            --remote-debugging-port="$port" \
            --remote-debugging-address=127.0.0.1 \
            about:blank \
            > "$(logfile)" 2>&1 &
        echo $! > "$(pidfile)"
        return 0
    fi

    echo "Error: Could not find Chromium binary after installation" >&2
    return 1
}

# Kill the browser process if running (fallback cleanup)
kill_browser() {
    local pf
    pf="$(pidfile)"
    if [ -f "$pf" ]; then
        local pid
        pid=$(cat "$pf")
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null || true
            # Wait briefly for graceful shutdown
            for _ in $(seq 1 10); do
                if ! kill -0 "$pid" 2>/dev/null; then break; fi
                sleep 0.2
            done
            # Force kill if still alive
            kill -9 "$pid" 2>/dev/null || true
        fi
        rm -f "$pf"
    fi
}

# Try to start browser via daemon API. Returns 0 on success, 1 on failure.
daemon_start_browser() {
    local port="$1"
    local result
    local http_code

    result=$(curl -s -w "\n%{http_code}" --connect-timeout 5 \
        -X POST "$API_BASE/api/sessions/$SESSION_ID/browser-start" \
        -H "Content-Type: application/json" \
        -d "{\"port\": $port}")
    http_code=$(echo "$result" | tail -n1)
    result=$(echo "$result" | sed '$d')

    if [[ "$http_code" == "200" ]]; then
        echo "Browser started via daemon." >&2
        return 0
    else
        echo "Daemon browser-start returned HTTP $http_code: $result" >&2
        return 1
    fi
}

# Try to stop browser via daemon API. Returns 0 on success, 1 on failure.
daemon_stop_browser() {
    local result
    local http_code

    result=$(curl -s -w "\n%{http_code}" --connect-timeout 5 \
        -X POST "$API_BASE/api/sessions/$SESSION_ID/browser-stop")
    http_code=$(echo "$result" | tail -n1)

    if [[ "$http_code" == "200" ]]; then
        return 0
    else
        return 1
    fi
}

# ----- Commands -----

do_start() {
    local port="$DEFAULT_PORT"

    # Parse --port
    shift  # skip --start
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)
                port="$2"
                shift 2
                ;;
            *)
                echo "Error: Unknown option: $1" >&2
                show_help
                exit 1
                ;;
        esac
    done

    # Step 0: Ensure system fonts are available for Chromium
    ensure_fonts

    # Step 1: Check/launch browser
    if curl -sf "http://localhost:$port/json/version" &>/dev/null; then
        echo "Browser already running on port $port" >&2
    else
        echo "Launching browser on port $port..." >&2

        # Try daemon API first, fall back to direct launch
        if ! daemon_start_browser "$port"; then
            echo "Falling back to direct launch..." >&2
            if ! launch_browser "$port"; then
                echo "Error: Failed to launch browser" >&2
                exit 1
            fi
        fi

        if ! wait_for_cdp "$port"; then
            echo "Error: Browser failed to start within 10s. Check log: $(logfile)" >&2
            exit 1
        fi
        echo "Browser started." >&2
    fi

    # Step 2: Create tunnel + browser view via API
    local bv_result
    bv_result=$(curl -s -w "\n%{http_code}" --connect-timeout 5 \
        -X POST "$API_BASE/api/sessions/$SESSION_ID/browser-view" \
        -H "Content-Type: application/json" \
        -d "{\"cdp_port\": $port}")
    local bv_http
    bv_http=$(echo "$bv_result" | tail -n1)
    bv_result=$(echo "$bv_result" | sed '$d')

    local browser_view=true
    if [[ "$bv_http" == "409" ]]; then
        echo "Browser view already active." >&2
    elif [[ "$bv_http" == "200" || "$bv_http" == "201" ]]; then
        echo "Browser view opened." >&2
    elif [[ "$bv_http" == "400" ]]; then
        # Not a remote worker — browser view not supported, but browser+MCP still work
        echo "Note: Browser view requires a remote (rdev) worker. Skipping view." >&2
        browser_view=false
    else
        echo "Warning: Browser view API returned HTTP $bv_http" >&2
        echo "$bv_result" >&2
        browser_view=false
    fi

    # Step 3: Get page URL from browser view response or CDP
    local page_url=""
    if [[ "$browser_view" == "true" ]]; then
        page_url=$(echo "$bv_result" | jq -r '.page_url // empty' 2>/dev/null || true)
    fi
    if [[ -z "$page_url" ]]; then
        page_url=$(curl -sf "http://localhost:$port/json" 2>/dev/null | jq -r '.[0].url // empty' 2>/dev/null || true)
    fi

    # Output JSON result
    jq -n \
        --argjson ok true \
        --argjson cdp_port "$port" \
        --arg page_url "$page_url" \
        --argjson browser_view "$browser_view" \
        '{ok: $ok, cdp_port: $cdp_port, page_url: $page_url, browser_view: $browser_view}'

    echo "" >&2
    echo "Browser started on port $port." >&2
    if [[ "$browser_view" == "true" ]]; then
        echo "Browser View opened in the dashboard." >&2
    fi
    echo "Playwright MCP tools are pre-configured to connect to this browser." >&2
}

do_close() {
    # Step 1: Close browser view via API
    local bv_result
    bv_result=$(curl -s -w "\n%{http_code}" --connect-timeout 5 \
        -X DELETE "$API_BASE/api/sessions/$SESSION_ID/browser-view")
    local bv_http
    bv_http=$(echo "$bv_result" | tail -n1)
    bv_result=$(echo "$bv_result" | sed '$d')

    if [[ "$bv_http" == "200" ]]; then
        echo "Browser view closed." >&2
    elif [[ "$bv_http" == "404" ]]; then
        echo "No active browser view." >&2
    else
        echo "Warning: Browser view close returned HTTP $bv_http" >&2
    fi

    # Step 2: Stop browser via daemon, fall back to PID file
    if daemon_stop_browser; then
        echo "Browser stopped via daemon." >&2
    else
        kill_browser
        echo "Browser stopped." >&2
    fi

    jq -n '{ok: true}'
}

do_status() {
    local port="$DEFAULT_PORT"
    local browser_running=false

    # Check browser via CDP
    if curl -sf "http://localhost:$port/json/version" &>/dev/null; then
        browser_running=true
    fi

    # Check browser view
    local bv_result
    bv_result=$(curl -sf --connect-timeout 5 \
        "$API_BASE/api/sessions/$SESSION_ID/browser-view" 2>/dev/null \
        || echo '{"active": false}')

    local bv_active
    bv_active=$(echo "$bv_result" | jq -r '.active // false')

    jq -n \
        --argjson browser_running "$browser_running" \
        --argjson browser_view_active "$bv_active" \
        --argjson cdp_port "$port" \
        '{browser_running: $browser_running, browser_view_active: $browser_view_active, cdp_port: $cdp_port}'
}

do_minimize() {
    result=$(curl -sf -X POST "$API_BASE/api/sessions/$SESSION_ID/browser-view/minimize" 2>&1) || {
        echo "Error: Failed to minimize browser view" >&2
        echo "$result" >&2
        exit 1
    }
    echo "$result" | jq .
    echo ""
    echo "Browser view minimized."
}

do_restore() {
    result=$(curl -sf -X POST "$API_BASE/api/sessions/$SESSION_ID/browser-view/restore" 2>&1) || {
        echo "Error: Failed to restore browser view" >&2
        echo "$result" >&2
        exit 1
    }
    echo "$result" | jq .
    echo ""
    echo "Browser view restored."
}

do_install() {
    echo "Installing Playwright Chromium..." >&2
    npx playwright install chromium
    ensure_fonts
    echo "Playwright Chromium installed."
}

# ----- Main dispatch -----

case "${1:-}" in
    -h|--help)
        show_help
        exit 0
        ;;
    --start)
        do_start "$@"
        ;;
    --close)
        do_close
        ;;
    --status)
        do_status
        ;;
    --minimize)
        do_minimize
        ;;
    --restore)
        do_restore
        ;;
    --install)
        do_install
        ;;
    *)
        show_help
        exit 0
        ;;
esac
