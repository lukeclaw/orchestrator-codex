#!/bin/bash
# orch-notify: Create non-blocking notification for user
source "$(dirname "$0")/lib.sh"

show_help() {
    echo "Usage: orch-notify <message> [options]"
    echo ""
    echo "Create a non-blocking notification for the user."
    echo ""
    echo "Options:"
    echo "  --type TYPE             Notification type (info|pr_comment|warning), default: info"
    echo "  --link URL              Optional external link (e.g., PR URL)"
    echo "  --subtask-id ID         Link notification to a subtask instead of the parent task"
    echo "  --message-stdin         Read additional message content from stdin (for multi-line messages)"
    echo ""
    echo "Examples:"
    echo "  orch-notify \"PR merged, but reviewer asked about error handling\""
    echo "  orch-notify \"Found potential issue in config\" --type warning"
    echo "  orch-notify \"PR #123 merged with comments\" --type pr_comment --link \"https://github.com/...\""
    echo ""
    echo "  # PR comment with auto-enrichment (fetches PR title, reviewer comment, and reply from GitHub):"
    echo "  orch-notify \"Replied to reviewer about error handling\" --type pr_comment \\"
    echo "    --link \"https://github.com/org/repo/pull/123#discussion_r456\""
    echo ""
    echo "  # Link notification to a specific subtask:"
    echo "  orch-notify \"Rate limiting PR merged\" --subtask-id SUBTASK_UUID --link \"https://github.com/...\""
    echo ""
    echo "  # Multi-line message (e.g., for PR comment replies):"
    echo "  orch-notify \"[Task: Fix auth] Replied to reviewer\" --type pr_comment --link \"URL\" --message-stdin <<'EOF'"
    echo "  Full text of my reply to the reviewer goes here."
    echo "  Can be multiple lines."
    echo "  EOF"
    echo ""
    echo "Guidelines:"
    echo "  - Use sparingly for valuable information that doesn't block your work"
    echo "  - ALWAYS notify when replying to PR comments or interacting with humans"
    echo "  - For pr_comment notifications with a GitHub PR link, metadata (PR title, reviewer"
    echo "    comment, your reply) is auto-extracted from the GitHub API"
    echo "  - Good: PR merged but reviewer left a question, found issue but proceeded safely"
    echo "  - Bad: Routine progress updates, status changes (use orch-task update instead)"
}

if [[ $# -eq 0 || "$1" == "-h" || "$1" == "--help" ]]; then
    show_help
    exit 0
fi

MESSAGE=""
NOTIFY_TYPE="info"
LINK_URL=""
SUBTASK_ID=""
MESSAGE_STDIN=false

MESSAGE="$1"
shift

while [[ $# -gt 0 ]]; do
    case "$1" in
        --type)
            NOTIFY_TYPE="$2"
            shift 2
            ;;
        --link)
            LINK_URL="$2"
            shift 2
            ;;
        --subtask-id)
            SUBTASK_ID="$2"
            shift 2
            ;;
        --message-stdin)
            MESSAGE_STDIN=true
            shift
            ;;
        *)
            echo "Unknown option: $1" >&2
            show_help
            exit 1
            ;;
    esac
done

if [[ -z "$MESSAGE" ]]; then
    echo "Error: Message is required" >&2
    show_help
    exit 1
fi

# If --message-stdin, append stdin content to the message
if [[ "$MESSAGE_STDIN" == true ]]; then
    STDIN_CONTENT=$(cat)
    if [[ -n "$STDIN_CONTENT" ]]; then
        MESSAGE="$MESSAGE

$STDIN_CONTENT"
    fi
fi

load_task_info "$FORCE_REFRESH"
# Note: We don't exit on failure - notification can be created without task_id

escaped_message=$(json_encode "$MESSAGE")
json="{\"message\": \"$escaped_message\", \"session_id\": \"$SESSION_ID\", \"notification_type\": \"$NOTIFY_TYPE\""

# If --subtask-id provided, use it as the task_id so the notification links to the subtask
if [[ -n "$SUBTASK_ID" ]]; then
    json="$json, \"task_id\": \"$SUBTASK_ID\""
elif [[ -n "$TASK_ID" && "$TASK_ID" != "null" ]]; then
    json="$json, \"task_id\": \"$TASK_ID\""
fi

if [[ -n "$LINK_URL" ]]; then
    json="$json, \"link_url\": \"$LINK_URL\""
fi

# Auto-enrich metadata for pr_comment notifications from GitHub API
# Parses the --link URL to fetch PR title, reviewer comment, and reply
if [[ "$NOTIFY_TYPE" == "pr_comment" && -n "$LINK_URL" ]]; then
    ENRICHED_METADATA=""

    # Parse GitHub PR URL: https://github.com/OWNER/REPO/pull/NUMBER[#fragment]
    if [[ "$LINK_URL" =~ github\.com/([^/]+)/([^/]+)/pull/([0-9]+) ]] && command -v gh &>/dev/null; then
        gh_owner="${BASH_REMATCH[1]}"
        gh_repo="${BASH_REMATCH[2]}"
        gh_pr_num="${BASH_REMATCH[3]}"
        gh_fragment=""
        if [[ "$LINK_URL" =~ \#(.+)$ ]]; then
            gh_fragment="${BASH_REMATCH[1]}"
        fi

        # Fetch PR title
        pr_title=$(gh api "repos/$gh_owner/$gh_repo/pulls/$gh_pr_num" --jq '.title' 2>/dev/null) || true

        reviewer_comment=""
        reviewer_name=""
        reviewer_commented_at=""
        reply_text=""
        reply_author=""
        reply_commented_at=""

        if [[ -n "$pr_title" ]]; then
            # Extract comment data based on URL fragment type
            if [[ "$gh_fragment" =~ ^discussion_r([0-9]+)$ ]]; then
                # Review comment (inline code comment) — has threading via in_reply_to_id
                comment_id="${BASH_REMATCH[1]}"
                reply_json=$(gh api "repos/$gh_owner/$gh_repo/pulls/comments/$comment_id" 2>/dev/null) || true
                if [[ -n "$reply_json" ]]; then
                    reply_text=$(echo "$reply_json" | jq -r '.body // ""') || true
                    reply_author=$(echo "$reply_json" | jq -r 'if .user.name and .user.name != "" then "\(.user.name) (\(.user.login))" else .user.login // "" end') || true
                    reply_commented_at=$(echo "$reply_json" | jq -r '.created_at // ""') || true
                    parent_id=$(echo "$reply_json" | jq -r '.in_reply_to_id // ""') || true
                    if [[ -n "$parent_id" && "$parent_id" != "null" && "$parent_id" != "" ]]; then
                        reviewer_json=$(gh api "repos/$gh_owner/$gh_repo/pulls/comments/$parent_id" 2>/dev/null) || true
                        if [[ -n "$reviewer_json" ]]; then
                            reviewer_comment=$(echo "$reviewer_json" | jq -r '.body // ""') || true
                            reviewer_name=$(echo "$reviewer_json" | jq -r 'if .user.name and .user.name != "" then "\(.user.name) (\(.user.login))" else .user.login // "" end') || true
                            reviewer_commented_at=$(echo "$reviewer_json" | jq -r '.created_at // ""') || true
                        fi
                    fi
                fi
            elif [[ "$gh_fragment" =~ ^issuecomment-([0-9]+)$ ]]; then
                # Issue comment (PR-level comment) — no threading, just fetch the body
                comment_id="${BASH_REMATCH[1]}"
                reply_json=$(gh api "repos/$gh_owner/$gh_repo/issues/comments/$comment_id" 2>/dev/null) || true
                if [[ -n "$reply_json" ]]; then
                    reply_text=$(echo "$reply_json" | jq -r '.body // ""') || true
                    reply_author=$(echo "$reply_json" | jq -r 'if .user.name and .user.name != "" then "\(.user.name) (\(.user.login))" else .user.login // "" end') || true
                    reply_commented_at=$(echo "$reply_json" | jq -r '.created_at // ""') || true
                fi
            fi

            # Build metadata JSON with proper escaping via jq
            ENRICHED_METADATA=$(jq -n \
                --arg title "$pr_title" \
                --arg rc "$reviewer_comment" \
                --arg rn "$reviewer_name" \
                --arg rca "$reviewer_commented_at" \
                --arg reply "$reply_text" \
                --arg ra "$reply_author" \
                --arg rpca "$reply_commented_at" \
                '{pr_title: $title}
                 + (if $rc != "" then {reviewer_comment: $rc} else {} end)
                 + (if $rn != "" then {reviewer_name: $rn} else {} end)
                 + (if $rca != "" then {reviewer_commented_at: $rca} else {} end)
                 + (if $reply != "" then {reply: $reply} else {} end)
                 + (if $ra != "" then {reply_author: $ra} else {} end)
                 + (if $rpca != "" then {reply_commented_at: $rpca} else {} end)' 2>/dev/null) || true
        fi
    fi

    if [[ -n "$ENRICHED_METADATA" ]]; then
        json="$json, \"metadata\": $ENRICHED_METADATA"
    fi
fi

json="$json}"

result=$(curl -s -X POST "$API_BASE/api/notifications" \
    -H 'Content-Type: application/json' \
    -d "$json")

echo "$result" | jq .

echo ""
echo "Notification created. User will see this in the dashboard."
