{
  "env": {
    "CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "false",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "true"
  },
  "spinnerTipsEnabled": false,
  "terminalProgressBarEnabled": false,
  "prefersReducedMotion": true,
  "autoUpdatesChannel": "stable",
  "permissions": {
    "allow": [
      "Bash(orch-tasks *)",
      "Bash(orch-workers *)",
      "Bash(orch-projects *)",
      "Bash(orch-ctx *)",
      "Bash(orch-notifications *)",
      "Bash(orch-send *)",
      "Bash(orch-tunnel *)",
      "Bash(gh *)",
      "Bash(captain *)",
      "Bash(tmux *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {"matcher": "Bash", "hooks": [{"type": "command", "command": "{{SAFETY_HOOK_PATH}}"}]}
    ],
    "UserPromptSubmit": [{"matcher": "", "hooks": [{"type": "command", "command": "{{INJECT_FOCUS_PATH}}"}]}]
  }
}
